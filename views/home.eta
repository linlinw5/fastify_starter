<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= it.title %></title>
    <link rel="stylesheet" href="/public/home.css" />
  </head>
  <body>
    <main class="card">
      <p class="eyebrow">Fastify Demo</p>
      <h1><%= it.title %></h1>
      <p>Your server is running successfully.</p>
      <div class="actions">
        <a class="button primary" href="/docs" target="_blank">Open API Docs</a>
        <a class="button secondary" href="/api/users" target="_blank">View Users API</a>
      </div>
    </main>
  </body>
</html>
